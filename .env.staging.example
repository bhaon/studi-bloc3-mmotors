# =============================================================================
# M-Motors — Staging (serveur de déploiement)
# Sur le serveur : copier vers .env — cp .env.staging .env
# Renseigner les secrets via GitHub Secrets / gestionnaire de secrets, pas en clair.
# =============================================================================

ENV=staging
SECRET_KEY=

# Base PostgreSQL (conteneur ou managé) — utilisateur DB aligné avec le dump CI (mmotors)
POSTGRES_USER=mmotors
POSTGRES_PASSWORD=
POSTGRES_DB=mmotors
DATABASE_URL=postgresql+asyncpg://mmotors:<mot-de-passe>@postgres:5432/mmotors

REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=https://staging.example.com

# URL publique de l’API pour le navigateur (IP ou DNS du serveur staging)
NEXT_PUBLIC_APP_ENV=staging
# URL de l’API telle qu’utilisée par le navigateur (alignée sur le déploiement)
NEXT_PUBLIC_API_URL=http://<adresse-ou-dns-staging>:8000

# Tag d’image GHCR (injecté par le pipeline : IMAGE_TAG=sha-<short-sha>)
# IMAGE_TAG=
