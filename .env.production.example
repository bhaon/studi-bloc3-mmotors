# =============================================================================
# M-Motors — Production (serveur de déploiement)
# Sur le serveur : copier vers .env — cp .env.production .env
# Obligatoire : SECRET_KEY fort, mots de passe uniques, HTTPS en frontal.
# =============================================================================

ENV=production
SECRET_KEY=

POSTGRES_USER=mmotors
POSTGRES_PASSWORD=
POSTGRES_DB=mmotors
DATABASE_URL=postgresql+asyncpg://mmotors:<mot-de-passe>@postgres:5432/mmotors

REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=https://www.example.com

NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_API_URL=https://api.example.com

# IMAGE_TAG=sha-<short-sha>
