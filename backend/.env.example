# =============================================================================
# M-Motors — Backend FastAPI
# Copier : cp .env.example .env
# Aucun secret ni mot de passe ne doit être commité : tout passe par ce fichier
# ou les variables d’environnement du conteneur / du CI.
# =============================================================================

# --- Obligatoires (plus de valeurs par défaut sensibles dans le code Python) ---
# Clé de signature JWT (ex. openssl rand -hex 32)
SECRET_KEY=

# URL SQLAlchemy synchrone (ex. PostgreSQL ou SQLite pour les tests)
DATABASE_URL=

# --- Optionnel ---
# ENV=test
# Origines CORS autorisées : CSV ou JSON tableau, ex. :
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# ALLOWED_ORIGINS=["http://localhost:3000","http://mmotors-frontend:3000"]

# =============================================================================
# Exemples (décommenter / adapter — ne pas réutiliser tels quels en production)
# =============================================================================

# Tests unitaires (SQLite)
# SECRET_KEY=mmotors-ci-test-secret-do-not-use-in-production-min-32chars
# DATABASE_URL=sqlite:///./test.db

# Tests d’intégration / CI PostgreSQL
# ENV=test
# SECRET_KEY=mmotors-ci-test-secret-do-not-use-in-production-min-32chars
# DATABASE_URL=postgresql://mmotors:mmotors_test@localhost:5432/mmotors_test
# REDIS_URL=redis://localhost:6379/0
