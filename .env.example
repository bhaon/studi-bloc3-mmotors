# Variables d'environnement (exemples).

# Propriétaire GitHub (namespace GHCR) — obligatoire pour pull staging/production
GHCR_OWNER=votre-org-ou-user-github

# Tag d’image (CI : IMAGE_TAG=sha-<short-sha>)
IMAGE_TAG=local

# URL publique d'API (navigateur), ex: https://app-dev.netdevops.fr/api
# NEXT_PUBLIC_API_URL=

# Backend
# DATABASE_URL=postgresql://user:pass@postgresql:5432/dbname
# SECRET_KEY=changez-moi (>= 32 chars)
