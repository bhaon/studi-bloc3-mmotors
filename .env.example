# Variables pour Docker Compose (copier vers .env à la racine du dépôt pour les tests locaux).
# Sur les serveurs, utiliser .env.staging / .env.production selon CICD-Workflow-doc.md.

# Propriétaire GitHub (namespace GHCR) — obligatoire pour pull staging/production
GHCR_OWNER=votre-org-ou-user-github

# Tag d’image (CI : IMAGE_TAG=sha-<short-sha>)
IMAGE_TAG=local

# Ports optionnels
# FRONTEND_PORT=3000
# BACKEND_PORT=8000
# NGINX_HTTP_PORT=8080
# NGINX_HTTPS_PORT=8443

# Reverse-proxy nginx : CN / SAN du certificat auto-signé (FQDN ou IP publique du VPS)
# Ex. accès https://217.154.126.103:8443 → SSL_CERT_CN=217.154.126.103
# Après changement : supprimer le volume nginx_ssl_data puis recréer le conteneur nginx.
# SSL_CERT_CN=localhost

# Accès Internet (pare-feu / hébergeur) :
# - Ouvrir les ports publiés (défaut) : NGINX_HTTPS_PORT (8443), NGINX_HTTP_PORT (8080)
#   Ex. UFW : sudo ufw allow 8443/tcp && sudo ufw allow 8080/tcp && sudo ufw reload
# - Sur cloud (AWS / Azure / OVH / etc.) : règle entrante « security group » pour ces ports.
# - URL application : https://<IP_PUBLIQUE>:8443 (sauf si NGINX_HTTPS_PORT=443).
# - Ports directs optionnels : FRONTEND_PORT (3000), BACKEND_PORT (8000) — à ouvrir si utilisés sans nginx.

# URL publique d'API (navigateur). Laisser vide derrière nginx HTTPS pour appeler /api en même origine.
# NEXT_PUBLIC_API_URL=
# SSR Next.js dans Docker : URL HTTPS vers uvicorn (réseau compose ; certificat dans volume internal_tls)
# NODE_EXTRA_CA_CERTS est défini dans docker-compose pour faire confiance au certificat interne.
# API_INTERNAL_URL=https://backend:8000

# Backend (pile complète uniquement)
# DATABASE_URL=postgresql://mmotors:mmotors@postgres:5432/mmotors
# REDIS_URL=redis://redis:6379/0
# SECRET_KEY=changez-moi
